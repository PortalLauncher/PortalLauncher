<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/PortalFragment">

    <fragment
        android:id="@+id/PortalFragment"
        android:name="de.szalkowski.activitylauncher.ui.PortalFragment"
        android:label="@string/portal_tab_title"
        tools:layout="@layout/fragment_portal" />

    <fragment
        android:id="@+id/LoadingFragment"
        android:name="de.szalkowski.activitylauncher.ui.LoadingFragment"
        android:label="@string/title_fragment_package_list"
        tools:layout="@layout/fragment_loading">
        <action
            android:id="@+id/actionLoadingFinished"
            app:destination="@id/PackageListFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:launchSingleTop="true"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"
            app:popUpTo="@id/LoadingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/PackageListFragment"
        android:name="de.szalkowski.activitylauncher.ui.PackageListFragment"
        android:label="@string/title_fragment_package_list"
        tools:layout="@layout/fragment_package_list">
        <action
            android:id="@+id/actionSelectPackage"
            app:destination="@id/ActivityListFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/ActivityListFragment"
        android:name="de.szalkowski.activitylauncher.ui.ActivityListFragment"
        android:label="@string/title_fragment_activity_list"
        tools:layout="@layout/fragment_activity_list">
        <argument
            android:name="packageName"
            app:argType="string"
            app:nullable="false" />
        <action
            android:id="@+id/actionSelectActivity"
            app:destination="@id/ActivityDetailsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/ActivityDetailsFragment"
        android:name="de.szalkowski.activitylauncher.ui.ActivityDetailsFragment"
        android:label="@string/context_action_edit"
        tools:layout="@layout/fragment_activity_details">
        <argument
            android:name="activityComponentName"
            app:argType="android.content.ComponentName"
            app:nullable="false" />
    </fragment>

    <fragment
        android:id="@+id/FavoritesFragment"
        android:name="de.szalkowski.activitylauncher.ui.FavoritesFragment"
        android:label="@string/nav_favorites"
        tools:layout="@layout/fragment_favorites" >
        <action
            android:id="@+id/actionSelectActivity"
            app:destination="@id/ActivityDetailsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/RecentsFragment"
        android:name="de.szalkowski.activitylauncher.ui.RecentsFragment"
        android:label="@string/nav_recents"
        tools:layout="@layout/fragment_recents">
        <action
            android:id="@+id/actionSelectActivity"
            app:destination="@id/ActivityDetailsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/PortalSettingsFragment"
        android:name="de.szalkowski.activitylauncher.ui.PortalSettingsFragment"
        android:label="@string/portal_settings_title"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settings_to_startup_edit"
            app:destination="@id/StartupItemEditFragment" />
    </fragment>

    <fragment
        android:id="@+id/StartupItemEditFragment"
        android:name="de.szalkowski.activitylauncher.ui.StartupItemEditFragment"
        android:label="@string/startup_item_edit_title"
        tools:layout="@layout/fragment_settings">
        <argument
            android:name="startup_item_index"
            app:argType="integer"
            android:defaultValue="-1" />
        <argument
            android:name="package_name"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="class_name"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

</navigation>
